# Normalize repository text files.
* text=auto

*.py text eol=lf
*.md text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.txt text eol=lf

# Windows launcher components and locally recreated BAT files.
*.ps1 text eol=crlf
*.vbs text eol=crlf
*.bat text eol=crlf

# Binary assets.
*.png binary
*.ico binary
