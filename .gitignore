# Python
venv/
.venv/
__pycache__/
*.py[cod]
.pytest_cache/

# Windows BAT launchers are generated only for release ZIPs.
# Authoritative contents live in BUILD.md. Never commit BAT files.
*.bat
sonario.ico
static/favicon.ico

# Runtime state
cache/*
!cache/.gitkeep
output/*
!output/.gitkeep
history/
logs/
*.log
.sonario.pid
.sonario.browser.pid
.sonario-browser-profile/
Sonario-shutdown-diagnostic-*.txt

# Secrets and provider usage
credentials/*
!credentials/.gitkeep

# Installers and downloaded local bridges
OllamaSetup.exe
Windows-Copilot-API/
Deepseek-API/

# Local archives and OS/editor files
*.zip
*.sha256
*.sha256.txt
.DS_Store
Thumbs.db
.vscode/
.idea/
