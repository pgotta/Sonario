venv/
__pycache__/
*.pyc
cache/*.json
output/*
!output/.gitkeep
!cache/.gitkeep
credentials/credentials.json
credentials/token.json
credentials/api_keys.json
credentials/groq_usage.json
.DS_Store
history/
history/*.json

# setup_all.bat and run.bat are tracked so Git clones and source ZIPs are usable.
# Other personal/local batch helpers remain untracked.
*.bat
!setup_all.bat
!run.bat

# Optional local LLM bridges (downloaded by their setup .bat, never committed)
Windows-Copilot-API/
Deepseek-API/
